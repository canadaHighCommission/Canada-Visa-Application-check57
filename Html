<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Canada Visa Verification Portal</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; margin: 0; padding: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
        .container { background: white; padding: 25px; border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.15); width: 95%; max-width: 420px; text-align: center; border-top: 10px solid #d52b1e; overflow-y: auto; max-height: 95vh; }
        
        /* Header */
        .flag { width: 60px; margin-bottom: 8px; }
        h2 { color: #d52b1e; margin: 5px 0; font-size: 18px; letter-spacing: 1px; text-transform: uppercase; }
        .sub-text { color: #666; font-size: 12px; margin-bottom: 20px; border-bottom: 1px solid #eee; padding-bottom: 10px; }

        /* Search Screen */
        .input-group { text-align: left; margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: 600; color: #444; font-size: 13px; }
        input { width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 10px; box-sizing: border-box; font-size: 15px; }
        .search-btn { width: 100%; padding: 15px; background-color: #d52b1e; color: white; border: none; border-radius: 10px; cursor: pointer; font-size: 18px; font-weight: bold; margin-top: 10px; transition: 0.3s; }
        .search-btn:hover { background-color: #b02318; }

        #map-area { margin-top: 20px; border-radius: 12px; overflow: hidden; border: 1px solid #ddd; }

        /* Result Screen */
        #result-screen { display: none; animation: slideUp 0.6s ease-out; }
        
        .photo-container { margin-bottom: 15px; }
        .user-photo { width: 120px; height: 145px; object-fit: cover; border: 3px solid #d52b1e; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.2); background-color: #eee; }

        .approved-sticker { 
            background: linear-gradient(135deg, #28a745, #218838);
            color: white; padding: 6px 20px; border-radius: 5px; 
            font-weight: 900; font-size: 16px; display: inline-block;
            transform: rotate(-3deg); border: 2px dashed #fff;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2); margin: 5px 0;
        }

        .info-table { width: 100%; margin-top: 15px; border-collapse: collapse; text-align: left; }
        .info-table td { padding: 8px 5px; border-bottom: 1px solid #f1f1f1; font-size: 13px; }
        .label { color: #888; width: 45%; }
        .value { color: #222; font-weight: bold; }

        /* Documents Section */
        .docs-section { margin-top: 20px; text-align: left; background: #f9f9f9; padding: 15px; border-radius: 10px; border: 1px solid #eee; }
        .doc-title { font-size: 14px; font-weight: bold; color: #333; margin-bottom: 10px; display: block; border-left: 4px solid #d52b1e; padding-left: 8px; }
        
        .doc-item { 
            display: flex; 
            align-items: center; 
            background: white; 
            padding: 12px; 
            border-radius: 8px; 
            margin-bottom: 10px; 
            border: 1px solid #ddd; 
            text-decoration: none; 
            color: #333; 
            font-size: 12px; 
            font-weight: 600;
            transition: 0.3s;
        }
        .doc-item:hover { background-color: #fff5f5; border-color: #d52b1e; }
        .doc-item img { width: 22px; margin-right: 12px; }

        .success-note { background-color: #fff9e6; border-left: 4px solid #ffc107; padding: 12px; margin-top: 15px; font-size: 12px; color: #856404; line-height: 1.4; text-align: left; }

        @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body onload="welcomeVoice()">

<div class="container">
    <img src="https://upload.wikimedia.org/wikipedia/commons/d/d9/Flag_of_Canada_%28Pantone%29.svg" class="flag">
    <h2>GOVERNMENT OF CANADA</h2>
    <p class="sub-text">Immigration and Citizenship Verification</p>

    <div id="search-screen">
        <div class="input-group">
            <label>Passport Number:</label>
            <input type="text" id="passport" placeholder="Enter Passport No.">
        </div>
        <div class="input-group">
            <label>Application ID:</label>
            <input type="text" id="appID" placeholder="Enter Application ID">
        </div>
        <button class="search-btn" onclick="startProcess()">VERIFY STATUS</button>

        <div id="map-area">
            <p style="font-size: 10px; color: #999; margin: 5px;">Office Location: Ottawa, Canada</p>
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2800.276412494958!2d-75.7012999!3d45.4215299!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4cce04ff4fe494ef%3A0x26bb54f8654817d7!2sParliament%20Hill!5e0!3m2!1sen!2sca!4v1622549234567!5m2!1sen!2sca" width="100%" height="150" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
        </div>
    </div>

    <div id="result-screen">
        <div class="photo-container">
            <img src="38633.jpg" class="user-photo" alt="MD MAMUN SARKER">
        </div>
        
        <div class="approved-sticker">APPROVED</div>
        <p style="font-size: 13px; color: #28a745; font-weight: bold; margin-top: 5px;">✔ Application successfully verified and approved</p>

        <table class="info-table">
            <tr><td class="label">Full Name:</td><td class="value">MD MAMUN SARKER</td></tr>
            <tr><td class="label">Passport Number:</td><td class="value">A12427399</td></tr>
            <tr><td class="label">Visa Category:</td><td class="value">Work Permit (IMM 1295)</td></tr>
            <tr><td class="label">Permit Number:</td><td class="value">Y9L3N7F0B3</td></tr>
            <tr><td class="label">Employer Name:</td><td class="value">MAGNA INTERNATIONAL</td></tr>
            <tr><td class="label">Expiry Date:</td><td class="value">27 February, 2031</td></tr>
        </table>

        <div class="docs-section">
            <span class="doc-title">Attached Official Documents</span>
            
            <a href="MAMUN SARKER - Work Permit.pdf" target="_blank" class="doc-item">
                <img src="https://cdn-icons-png.flaticon.com/512/337/337946.png">
                <span>View Work Permit (PDF)</span>
            </a>

            <a href="MAMUN SARKER JOB LETTER.pdf" target="_blank" class="doc-item">
                <img src="https://cdn-icons-png.flaticon.com/512/337/337946.png">
                <span>View Job Offer Letter (PDF)</span>
            </a>

            <a href="MAMUN SARKER - LMAI.pdf" target="_blank" class="doc-item">
                <img src="https://cdn-icons-png.flaticon.com/512/337/337946.png">
                <span>View LMIA Document (PDF)</span>
            </a>

            <a href="MAMUN SARKER APPLICATION  APPLY_.pdf" target="_blank" class="doc-item">
                <img src="https://cdn-icons-png.flaticon.com/512/337/337946.png">
                <span>View Application Copy (PDF)</span>
            </a>
        </div>

        <div class="success-note">
            <strong>Success!</strong> Your Canadian Visa and Work Permit documents have been issued. Please download the files from the links above.
        </div>
    </div>
</div>

<script>
    // updated credentials for MAMUN SARKER
    const VALID_PASSPORT = "A12427399"; 
    const VALID_APPID = "EGP87FKT51";

    function welcomeVoice() {
        const msg = new SpeechSynthesisUtterance();
        msg.text = "Welcome to Canada Visa Online Platform";
        msg.lang = 'en-US';
        window.speechSynthesis.speak(msg);
    }

    function speak(text) {
        const msg = new SpeechSynthesisUtterance();
        msg.text = text;
        msg.lang = 'en-US';
        window.speechSynthesis.speak(msg);
    }

    function startProcess() {
        const ppInput = document.getElementById('passport').value.trim();
        const idInput = document.getElementById('appID').value.trim();

        if(!ppInput || !idInput) {
            alert("Please provide required information");
            return;
        }

        const btn = document.querySelector('.search-btn');
        btn.innerHTML = "Verifying...";

        setTimeout(() => {
            if(ppInput === VALID_PASSPORT && idInput === VALID_APPID) {
                document.getElementById('search-screen').style.display = 'none';
                document.getElementById('result-screen').style.display = 'block';
                speak("Congratulations Mamun Sarker! Your application is successfully approved.");
            } else {
                btn.innerHTML = "VERIFY STATUS";
                alert("Invalid Information provided");
                speak("Sorry, information not found.");
            }
        }, 2000);
    }
</script>

</body>
</html>
